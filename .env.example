# --- core ---
POPSTACK_VAULT=~/Documents/kb
POPSTACK_DIR=Stack
POPSTACK_ACTIVE_LIMIT=20
POPSTACK_COOLDOWN_HOURS=4

# Knowledge vaults that grounding searches (comma-separated). The Stack vault
# (POPSTACK_VAULT) is always included. Set this to your complementary vaults so
# grounding can find — and connect — across them.
POPSTACK_VAULTS=~/Documents/kb,~/Documents/coding,~/Documents/formalisms

# Where the agent WRITES new notes. Defaults to a quarantine folder
# (<NOTES_VAULT>/<NOTES_DIR>) so agent-authored notes never silently mix into
# your KB until you file them. Point NOTES_VAULT at a knowledge vault to write
# into it; keep NOTES_DIR as a clearly-marked subfolder.
POPSTACK_NOTES_VAULT=~/Documents/kb
POPSTACK_NOTES_DIR=popstack
# Where cloned repos land for codebase learning goals.
POPSTACK_WORKSPACE=~/.popstack/repos

# --- HTTP transport (claude.ai connector via Tailscale Funnel) ---
POPSTACK_HOST=127.0.0.1
POPSTACK_PORT=8444
# REQUIRED before exposing via Funnel:  openssl rand -hex 32
POPSTACK_AUTH_TOKEN=

# --- Zotero (reads use the local API; writes need a web API key) ---
ZOTERO_LOCAL_URL=http://localhost:23119/api/users/0
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# --- Anki (optional) ---
ANKI_URL=http://localhost:8765
# Last-resort fallback deck only. The agent should choose a TOPIC deck per card
# set (hierarchical via '::', e.g. ML::Papers::pi0); this is used only if none
# is specified.
ANKI_DEFAULT_DECK=popstack::inbox
